APP_ENV=production
APP_NAME=RAG Agent Customer Service
PUBLIC_BASE_URL=https://your-domain.example.com

# Model providers: mock | openai_compatible
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=replace-me
LLM_MODEL=qwen-plus

# Embedding providers: hash | openai_compatible
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=replace-me
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

# Stores: memory | postgres/qdrant/redis
CONVERSATION_STORE=postgres
VECTOR_STORE=qdrant
IDEMPOTENCY_STORE=redis
DATABASE_URL=postgresql://rag:rag_password@postgres:5432/rag
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kb_chunks

KB_DIR=data/kb
CHUNK_SIZE=700
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.62
FALLBACK_MESSAGE=抱歉，我暂时没有在知识库中找到可靠答案。请换一种问法，或稍后联系人工客服。

ADMIN_TOKEN=change-this-admin-token

# WeCom callback settings
WECOM_TOKEN=replace-me
WECOM_ENCODING_AES_KEY=
WECOM_CORP_ID=

# Feishu callback and API settings
FEISHU_VERIFICATION_TOKEN=replace-me
FEISHU_APP_ID=replace-me
FEISHU_APP_SECRET=replace-me
FEISHU_ENCRYPT_KEY=

